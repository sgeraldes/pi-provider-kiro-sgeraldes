{
  "name": "pi-provider-kiro-sgeraldes",
  "version": "0.4.5-sgeraldes.0",
  "description": "Personal fork of pi-provider-kiro for the Kiro API (AWS CodeWhisperer/Q)",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sgeraldes/pi-provider-kiro-sgeraldes.git"
  },
  "keywords": [
    "pi",
    "kiro",
    "aws",
    "codewhisperer",
    "ai",
    "provider"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "pi": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.2",
    "@mariozechner/pi-ai": "^0.53.0",
    "@mariozechner/pi-coding-agent": "^0.53.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "js-tiktoken": "^1.0.21"
  },
  "homepage": "https://github.com/sgeraldes/pi-provider-kiro-sgeraldes#readme",
  "bugs": {
    "url": "https://github.com/sgeraldes/pi-provider-kiro-sgeraldes/issues"
  },
  "author": "sgeraldes"
}
